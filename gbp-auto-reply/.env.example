# ============================================================
# GBP Auto-Reply — Environment Configuration
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ─── App ─────────────────────────────────────────────────────
APP_NAME=gbp-auto-reply
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
ADMIN_PASSWORD=change-me-admin-password
LOG_LEVEL=INFO

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://gbp_user:gbp_pass@localhost:5432/gbp_auto_reply
ASYNC_DATABASE_URL=postgresql+asyncpg://gbp_user:gbp_pass@localhost:5432/gbp_auto_reply

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Celery ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Google OAuth 2.0 ────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/callback

# ─── Google Sheets (Template Source — BACKEND ONLY) ──────────
# These are NEVER exposed in the admin UI.
TEMPLATE_SPREADSHEET_ID=your-google-spreadsheet-id
TEMPLATE_WORKSHEET_NAME=Sheet1
TEMPLATE_RANGE=A:A
TEMPLATE_CACHE_TTL_SECONDS=300

# ─── Encryption Key for Stored Tokens ────────────────────────
TOKEN_ENCRYPTION_KEY=change-me-to-a-fernet-compatible-key

# ─── Scheduler ───────────────────────────────────────────────
DEFAULT_SCHEDULE_INTERVAL_MINUTES=60
SCHEDULER_TICK_INTERVAL_SECONDS=60

# ─── Rate Limiting ───────────────────────────────────────────
GBP_API_RATE_LIMIT_PER_MINUTE=60
SHEETS_API_RATE_LIMIT_PER_MINUTE=30
